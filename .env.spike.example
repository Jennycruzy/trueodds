# G0 spike configuration — copy to .env.spike and fill in.
#
#   cp .env.spike.example .env.spike
#   chmod 600 .env.spike
#
# .env.spike is gitignored. Nothing in this repo prints its contents, and the
# spike script redacts every value it loads. Do not paste the private key into
# a chat, a terminal you are screen-sharing, or a prompt.
#
# ---------------------------------------------------------------------------
# RULES FOR THIS KEY — it is a throwaway, not a wallet you care about
# ---------------------------------------------------------------------------
#   * Generate a BRAND NEW wallet for this spike. Never reuse the x402 payment
#     wallet, the Agent #5560 identity wallet, or anything holding real balance.
#   * Fund it with the minimum that lets one order rest — a couple of dollars.
#   * Run this on your laptop or a scratch box. NOT on the production VPS.
#   * When G0 is signed off, drain it and discard the key.
#
# To generate one locally (never prints to a shared terminal):
#   python -c "from eth_account import Account; a=Account.create(); \
#     print(a.key.hex()); print(a.address)"

# The throwaway EOA private key (0x-prefixed hex). REQUIRED.
SPIKE_PRIVATE_KEY=

# The address that holds the funds. For an EOA setup this equals the address
# derived from SPIKE_PRIVATE_KEY. For a POLY_1271 deposit wallet this is the
# deposit wallet address. Leave blank with SPIKE_SIGNATURE_TYPE=3 and the script
# will derive the deterministic deposit wallet from SPIKE_PRIVATE_KEY.
SPIKE_FUNDER_ADDRESS=

# Polymarket signature type: 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE,
# 3 = POLY_1271. Start at 0 for the simplest possible proof.
SPIKE_SIGNATURE_TYPE=0

# The market to rest an order in. Fill both from --pick-market.
# SPIKE_CONDITION_ID is required by the on-chain preflight, because whether the
# market is neg_risk decides WHICH exchange contract needs the allowance.
SPIKE_TOKEN_ID=
SPIKE_CONDITION_ID=

# Order parameters. Keep tiny. Price must be on-tick; size at or above the
# venue minimum (currently 5).
#
# PRICE IT TO REST, NOT TO FILL. G0 needs the venue to *accept* the order, not
# to trade it. A BUY at or above the best ask fills immediately and leaves you
# holding a position; a BUY well below it just rests in the book, which proves
# exactly the same thing and cancels for free.
SPIKE_SIDE=BUY
SPIKE_PRICE=0.02
SPIKE_SIZE=5

# ---------------------------------------------------------------------------
# WHAT TO FUND — the address is the authority, not the symbol
# ---------------------------------------------------------------------------
# Collateral: bridged USDC.e on Polygon
#     0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174   "USD Coin (PoS)"
# NOT native Circle USDC
#     0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359   "USD Coin"
# Both report symbol "USDC" with 6 decimals on Polygon. Fund the wrong one and
# your wallet shows a balance you cannot trade with. The preflight checks this
# and names it if you have.
#
# Also hold ~1 POL for gas. Gas is only needed for the one-time approval, not
# per order -- CLOB orders match off-chain.

# Chain / host. Polygon mainnet is 137.
SPIKE_CHAIN_ID=137
SPIKE_CLOB_HOST=https://clob.polymarket.com

# Deposit-wallet relayer. Needed for autonomous WALLET-CREATE and WALLET batch
# operations such as deploy and approvals. Order signing itself uses the CLOB
# client above.
SPIKE_RELAYER_URL=https://relayer-v2.polymarket.com
SPIKE_POLYGON_RPC_URL=https://polygon.drpc.org
